APP_NAME="Ysabelle Store"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mariadb
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=ysabelle_store
DB_USERNAME=root
DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=smtp
MAIL_SCHEME=null
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=ysabelleretail@gmail.com
MAIL_PASSWORD=
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS=ysabelleretail@gmail.com
MAIL_FROM_NAME="Ysabelle Retail Support"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=llama3.2:3b
OLLAMA_TIMEOUT=8
OLLAMA_TEMPERATURE=0.2
OLLAMA_MAX_TOKENS=96
STOREFRONT_VISUAL_SEARCH_EMBEDDINGS_ENABLED=true
STOREFRONT_VISUAL_SEARCH_PYTHON=python
STOREFRONT_VISUAL_SEARCH_SCRIPT=
STOREFRONT_VISUAL_SEARCH_EMBEDDING_MODEL=openai/clip-vit-base-patch32
STOREFRONT_VISUAL_SEARCH_EMBEDDING_VERSION=clip-b32-v1
STOREFRONT_VISUAL_SEARCH_EMBEDDING_TIMEOUT=120
STOREFRONT_VISUAL_SEARCH_STRONG_MATCH=0.92
STOREFRONT_VISUAL_SEARCH_LIKELY_MATCH=0.86
STOREFRONT_VISUAL_SEARCH_SIMILAR_MATCH=0.78
STOREFRONT_VISUAL_SEARCH_MIN_CANDIDATE=0.72
STOREFRONT_VISUAL_SEARCH_SHOE_FLOOR=0.5
STOREFRONT_VISUAL_SEARCH_BLUR_FLOOR=0.0035
STOREFRONT_VISUAL_SEARCH_DEBUG=false
